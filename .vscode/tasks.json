{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure (debug)",
            "type": "shell",
            "command": "D:/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": ["--preset", "debug"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": []
        },
        {
            "label": "CMake: build (debug)",
            "type": "shell",
            "command": "D:/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": ["--build", "--preset", "debug"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$gcc"],
            "dependsOn": "CMake: configure (debug)",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
